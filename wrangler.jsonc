{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xgov",
  "main": "./dist/_worker.js/index.js",
  // Update to today's date
  "compatibility_date": "2025-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "r2_buckets": [
    {
      "binding": "COMMITTEE_BUCKET",
      "bucket_name": "xgov",
      "remote": true,
    },
  ],
  "observability": {
    "enabled": true,
  },
}
